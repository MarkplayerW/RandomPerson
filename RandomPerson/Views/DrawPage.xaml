<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomPerson.Views.DrawPage"
             Title="Losowanie Osoby"
             StyleClass="page">
    <VerticalStackLayout StyleClass="container" VerticalOptions="Center" Spacing="20">
        <Label x:Name="DrawnStudentLabel" Text="?" StyleClass="title, lucky-number" />
        <Button Text="Losuj" Clicked="OnDrawStudent" StyleClass="btn-accent" />
        <Button Text="Powrót" Clicked="OnBack" StyleClass="btn-primary" />
    </VerticalStackLayout>
</ContentPage>