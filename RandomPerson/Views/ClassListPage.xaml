<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomPerson.Views.ClassListPage"
             Title="Edycja Listy"
             StyleClass="page">
    <VerticalStackLayout StyleClass="container">
        <Entry x:Name="NewStudentEntry" Placeholder="Imię i nazwisko" StyleClass="entry" />
        <Button Text="Dodaj ucznia" Clicked="OnAddStudent" StyleClass="btn-primary" />
        <ListView x:Name="StudentsListView" HasUnevenRows="True" Margin="0,20,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <HorizontalStackLayout Spacing="10" StyleClass="student-row">
                            <Label Text="{Binding Name}" VerticalOptions="Center" />
                            <Switch IsToggled="{Binding IsPresent}" VerticalOptions="Center" />
                            <Button Text="Usuń" CommandParameter="{Binding}" Clicked="OnDeleteStudent" StyleClass="btn-danger" />
                        </HorizontalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Text="Zapisz" Clicked="OnSave" StyleClass="btn-accent" Margin="0,20,0,0"/>
        <Button Text="Powrót" Clicked="OnBack" StyleClass="btn-primary" Margin="0,10,0,0"/>
    </VerticalStackLayout>
</ContentPage>